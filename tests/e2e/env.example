# Copy to tests/e2e/.env.local (or export in your shell).
# Used by Playwright specs: full-plugin-ui-journey.spec.ts, capture-sop-screenshots.spec.ts
#
#   cp tests/e2e/env.example tests/e2e/.env.local
#   source tests/e2e/load-env.sh
#   npm run test:e2e:headed

# Site URL (no trailing slash)
PR_E2E_BASE_URL=http://localhost:10008

# Coordinator: project_reviews_coordinator (or admin with caps)
PR_E2E_COORD_USER=pr_e2e_coordinator
PR_E2E_COORD_PASS=pr-e2e-change-me

# Reviewer: project_reviews_reviewer
PR_E2E_REVIEWER_USER=pr_e2e_reviewer
PR_E2E_REVIEWER_PASS=pr-e2e-change-me

# Must match the email entered in the setup wizard reviewer step
PR_E2E_REVIEWER_EMAIL=pr_e2e_reviewer@example.test

# Optional: used by tests/e2e/bin/seed-e2e-users.php when creating accounts
# PR_E2E_DEFAULT_PASSWORD=pr-e2e-change-me
# PR_E2E_COORD_EMAIL=pr_e2e_coordinator

# Optional: reuse an existing SOP screenshot folder (trailing slash)
# PR_SOP_SCREENSHOTS_DIR=screenshots/2026-05-21_143022/
