{
  "name": "scorva",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "sync": "browser-sync start --config browser-sync.config.js",
    "dev": "npm-run-all --parallel sync start",
    "test:e2e": "playwright test tests/e2e/specs/full-plugin-ui-journey.spec.ts",
    "test:e2e:headed": "playwright test tests/e2e/specs/full-plugin-ui-journey.spec.ts --headed",
    "walkthrough:coordinator": "playwright test tests/e2e/specs/coordinator-walkthrough.spec.ts --headed --project=walkthrough",
    "walkthrough:reviewer": "playwright test tests/e2e/specs/reviewer-walkthrough.spec.ts --headed --project=walkthrough",
    "walkthrough:coordinator:finish": "playwright test tests/e2e/specs/coordinator-walkthrough-finish.spec.ts --headed --project=walkthrough",
    "walkthrough:all": "npm run walkthrough:coordinator && npm run walkthrough:reviewer && npm run walkthrough:coordinator:finish",
    "test:e2e:all": "playwright test",
    "test:e2e:sop": "playwright test tests/e2e/specs/capture-sop-screenshots.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "sop:screenshots": "playwright test tests/e2e/specs/capture-sop-screenshots.spec.ts",
    "sop:screenshots:headed": "playwright test tests/e2e/specs/capture-sop-screenshots.spec.ts --headed",
    "dist": "bash bin/release.sh --skip-tests",
    "dist:full": "bash bin/release.sh",
    "reset": "composer test:teardown -- --confirm",
    "reset:dry-run": "composer test:teardown -- --dry-run"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.15.0",
    "@wordpress/components": "^28.13.0",
    "@wordpress/element": "^6.15.0",
    "react": "^18.3.1",
    "react-circular-progressbar": "^2.2.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@wordpress/scripts": "^32.4.0",
    "autoprefixer": "^10.4.20",
    "browser-sync": "^2.29.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
